  -- Running total of sales by month
  WITH monthly_sales AS (
SELECT DATE_TRUNC('month',o.OrderDate)::DATE AS month,
       SUM(Quantity*UnitPrice)-SUM(Discount) AS monthly_sales
  FROM orders AS o
  JOIN order_details AS od
    ON od.order_id = o.order_id
 GROUP BY DATE_TRUNC('month',o.order_date)
)

SELECT month AS "Month", 
       monthly_sales AS "Monthly Sales",
       SUM(monthly_sales) OVER(ORDER BY month) AS "Running Total"
  FROM monthly_sales
 ORDER BY month;
  

